{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": [
    "domain/*.ts",
    "pages/*.ts",
    "tests/**/*.ts",
    "playwright.config.ts",
    "fixtures/*.ts",
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}